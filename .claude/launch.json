{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const http=require('http');http.createServer((req,res)=>{res.writeHead(302,{Location:'http://localhost:3000'+req.url});res.end();}).listen(process.env.PORT||3001,()=>console.log('redirect proxy up on '+(process.env.PORT||3001)));"
      ],
      "port": 3000,
      "autoPort": true
    }
  ]
}

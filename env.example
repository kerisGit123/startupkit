# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com  # used for Kie AI callback URLs

# ── Clerk Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Convex ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=prod:...   # for CI/CD production deploys

# ── Kie AI (script gen + image gen + video gen) ───────────────────────────────
KIE_AI_API_KEY=kie_...       # from https://kie.ai/dashboard

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=abc123...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=storyboardbucket
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev  # public R2 bucket URL for displaying images
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev  # or your custom domain

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Support Chatbot & AI Director ─────────────────────────────────────────────
# Primary: DeepSeek V3 via OpenRouter (cheap). Fallback: Claude Haiku via Anthropic.
OPENROUTER_API_KEY=sk-or-...                           # from https://openrouter.ai/keys
ANTHROPIC_API_KEY=sk-ant-...                           # from https://console.anthropic.com/ (fallback + Agent mode)
# Gate server-only convex/supportTools.* functions from direct client calls.
# Pick a long random string, set the SAME value in `.env.local` AND as a Convex
# environment variable: `npx convex env set SUPPORT_INTERNAL_SECRET <value>`
SUPPORT_INTERNAL_SECRET=generate-a-long-random-string
